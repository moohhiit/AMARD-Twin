# RailMind AI - Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=RailMind AI
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Neo4j Aura Free
NEO4J_URI=neo4j+s://fcde3b36.databases.neo4j.io
NEO4J_USERNAME=fcde3b36
NEO4J_PASSWORD=1g199KCNbB3DbI3mXlIcoROtLO09Gq7e1i7-vcjzJLg
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=30.0

# Event Bus
EVENT_BUS_MAX_QUEUE_SIZE=10000
EVENT_BUS_WORKER_COUNT=4

# WebSocket
WS_HEARTBEAT_INTERVAL=30.0
WS_MAX_CONNECTIONS=1000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security
ALLOWED_ORIGINS=["*"]
API_KEY_HEADER=X-API-Key

# Digital Twin
DIGITAL_TWIN_UPDATE_INTERVAL=1.0
SIMULATION_SPEED_FACTOR=1.0